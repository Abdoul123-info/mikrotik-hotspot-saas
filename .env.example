# =====================================================
# HOTSPOT MANAGER — Variables d'environnement
# Copiez ce fichier en ".env" et remplissez les valeurs
# =====================================================

# Port d'écoute du serveur (3001 en local, Railway le gère automatiquement)
PORT=3001

# Clé secrète pour sécuriser l'accès au proxy
# Générez une clé aléatoire forte (ex: openssl rand -hex 32)
API_SECRET=changez_cette_valeur_en_quelque_chose_de_secret

# --- Variables Vite (Frontend) ---
# Ces variables sont injectées dans le build React
# La clé DOIT correspondre à API_SECRET ci-dessus
VITE_API_SECRET=changez_cette_valeur_en_quelque_chose_de_secret
